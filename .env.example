# ==============================================
# LLM Configuration
# ==============================================
# Model selection (LiteLLM format): gemini-2.5-flash, openai/gpt-4o,
# anthropic/claude-..., ollama/llama3.2, ...
MODEL_NAME=gemini-2.5-flash

# API Keys (at least one, matching MODEL_NAME)
GOOGLE_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local LLM (optional) - start Ollama with: docker compose --profile local-llm up
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
LOCAL_LLM_API_KEY=ollama

# ==============================================
# Agent Configuration
# ==============================================
# Set to 'true' to enable Enforcer Mode (forces tool usage, Ulysses Pact)
ENABLE_ENFORCER_MODE=false

# Colon-separated extra skill directories (defaults to agent/skills)
#AGENT_SKILLS_DIRS=/app/skills:/app/provider_skills

# Langfuse Configuration (optional - for monitoring/tracing)
# Get keys from: https://cloud.langfuse.com
#LANGFUSE_PUBLIC_KEY=pk-lf-...
#LANGFUSE_SECRET_KEY=sk-lf-...
#LANGFUSE_HOST=https://cloud.langfuse.com

# ==============================================
# AP2 Payment Protocol (Experimental - Solana)
# ==============================================
# Set to 'true' to enable agent-to-agent payment features
ENABLE_AP2_PROTOCOL=false

# Set to 'true' for mock mode (no real transactions; recommended)
SOLANA_USE_MOCK=true

# Solana network: devnet, mainnet, or custom RPC URL
SOLANA_NETWORK=devnet

# Solana private key (base58 or JSON array format)
# Generate with: solana-keygen new
#SOLANA_PRIVATE_KEY=your_solana_private_key

# Custom RPC URL (optional, defaults to public Devnet)
#SOLANA_RPC_URL=https://api.devnet.solana.com
